# Copy to .lastchaos_full_bundle.env (same directory) and fill in paths.
# scripts/build_full_macos_app.sh sources it automatically.

# Path to a macOS Mach-O game client executable (not available from this repo’s CMake yet).
LASTCHAOS_CLIENT_BINARY=

# Directory that contains Data/ or data/ (full client runtime from a Windows install or archive).
LASTCHAOS_ASSET_ROOT=

# Optional: explicit path to MoltenVK/Vulkan dylib to bundle into LastChaos.app/Contents/Frameworks
# If empty, scripts probe common Homebrew locations automatically.
# LASTCHAOS_MOLTENVK_DYLIB=/opt/homebrew/lib/libMoltenVK.dylib

# Optional: override login endpoint written to sl.dta inside the app bundle.
# LASTCHAOS_LOGIN_NAME=Local
# LASTCHAOS_LOGIN_HOST=127.0.0.1
# LASTCHAOS_LOGIN_PORT=4001
# LASTCHAOS_LOGIN_VERSION=1000
# LASTCHAOS_LOGIN_USERS=300

# Optional: set to 1 to also create build/macos/LastChaos.dmg
# LASTCHAOS_CREATE_DMG=1
