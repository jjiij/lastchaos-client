public:
	CmdWareHouseIconDown() : m_pWnd(NULL), nIndex_(-1)	{}
	void setData(CWareHouseUI* pWnd, int nIndex)	{ m_pWnd = pWnd; nIndex_ = nIndex; }
	void execute() 
	{
		if (m_pWnd != NULL)
			m_pWnd->WareIconMouseLDownEvent(nIndex_);
	}
private:
	CWareHouseUI* m_pWnd;
	int nIndex_;
};

